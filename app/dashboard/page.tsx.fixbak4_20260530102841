'use client';

import { useSession, signOut } from 'next-auth/react';
import { useRouter } from 'next/navigation';
import { useEffect, useState } from 'react';
import Link from 'next/link';
import { GlobalTheme } from '@/app/components/GlobalTheme';

export default function DashboardPage() {
  const { data: session, status } = useSession();
  const router = useRouter();
  const [characterData, setCharacterData] = useState<any>(null);
  const [votingLogs, setVotingLogs] = useState<any[]>([]);
  const [claimingReward, setClaimingReward] = useState(false);
  const [isAdmin, setIsAdmin] = useState(false);
  const [timePoints, setTimePoints] = useState<number>(0);

  useEffect(() => {
    if (status === 'unauthenticated') {
      router.push('/login');
    } else if (status === 'authenticated') {
      fetchUserData();
      fetchVotingLogs();
      checkAdminStatus();
      fetchTimePoints();
    }
  }, [status, router]);

  const checkAdminStatus = async () => {
    try {
      const response = await fetch('/api/admin/check');
      const data = await response.json();
      setIsAdmin(data.isAdmin);
    } catch (error) {
      console.error('Error checking admin status:', error);
    }
  };

  const fetchTimePoints = async () => {
    try {
      const response = await fetch('/api/user/time-points');
      if (response.ok) {
        const data = await response.json();
        setTimePoints(typeof data.points === 'number' ? data.points : 0);
      }
    } catch (error) {
      console.error('Error fetching time points:', error);
    }
  };

  const fetchUserData = async () => {
    try {
      const response = await fetch('/api/user/characters');
      const data = await response.json();
      setCharacterData(data);
    } catch (error) {
      console.error('Error fetching user data:', error);
    }
  };

  const fetchVotingLogs = async () => {
    try {
      const response = await fetch('/api/user/voting-logs');
      const data = await response.json();
      setVotingLogs(data);
    } catch (error) {
      console.error('Error fetching voting logs:', error);
    }
  };

  const handleClaimReward = async () => {
    setClaimingReward(true);
    try {
      const response = await fetch('/api/voting/reward', { method: 'POST' });
      const data = await response.json();
      if (response.ok) {
        alert(data.message);
        fetchUserData();
      } else {
        alert(data.error);
      }
    } catch (error) {
      alert('An error occurred');
    } finally {
      setClaimingReward(false);
    }
  };

  if (status === 'loading') {
    return (
      <GlobalTheme>
        <div className="flex-1 flex items-center justify-center">
          <div className="text-[var(--color-royal-gold)] text-2xl">Loading...</div>
        </div>
      </GlobalTheme>
    );
  }

  return (
    <GlobalTheme>
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
        <div className="mb-8">
          <h1 className="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-2">
            Welcome, {session?.user?.name}! ðŸ‘‹
          </h1>
          <p className="text-slate-400">Manage your account and characters</p>
        </div>

        {/* Stats Grid */}
        <div className="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
          {/* Profile Card */}
          <div className="metallic-card p-6 border-l-4 border-[var(--color-royal-gold)]">
            <div className="flex items-center justify-between mb-4">
              <h3 className="text-lg font-semibold text-[var(--color-royal-gold)]">Profile</h3>
              <span className="text-2xl">👤</span>
            </div>
            <div className="space-y-3">
              <div>
                <p className="text-slate-400 text-sm">Username</p>
                <p className="text-slate-200 font-medium">{session?.user?.name}</p>
              </div>
              <div>
                <p className="text-slate-400 text-sm">Email</p>
                <p className="text-slate-200 font-medium text-sm break-all">{session?.user?.email}</p>
              </div>
            </div>
          </div>

          {/* Credits Card */
          }
          <div className="metallic-card p-6 border-l-4 border-[var(--color-glowing-cyan)]">
            <div className="flex items-center justify-between mb-4">
              <h3 className="text-lg font-semibold text-[var(--color-glowing-cyan)]">Credits</h3>
              <span className="text-2xl">💰</span>
            </div>
            <p className="text-4xl font-bold text-[var(--color-royal-gold)]">{Number(session?.user?.coins || 0).toLocaleString()}</p>
            <p className="text-slate-400 text-sm mt-2">In-Game Coins</p>
          </div>

          {/* Time Points Card */}
          <div className="metallic-card p-6 border-l-4 border-[var(--color-royal-gold)]">
            <div className="flex items-center justify-between mb-4">
              <h3 className="text-lg font-semibold text-[var(--color-royal-gold)]">Time Points</h3>
              <span className="text-2xl">⏱️</span>
            </div>
            <p className="text-4xl font-bold text-[var(--color-royal-gold)]">{Number(timePoints || 0).toLocaleString()}</p>
            <p className="text-slate-400 text-sm mt-2">Activity and Timer Rewards</p>
          </div>

          {/* Characters Card */}
          <div className="metallic-card p-6 border-l-4 border-[var(--color-mystical-blue)]">
            <div className="flex items-center justify-between mb-4">
              <h3 className="text-lg font-semibold text-[var(--color-mystical-blue)]">Characters</h3>
              <span className="text-2xl">👥</span>
            </div>
            <p className="text-4xl font-bold text-[var(--color-royal-gold)]">{Number(characterData?.characters?.length || 0).toLocaleString()}</p>
            <p className="text-slate-400 text-sm mt-2">Total characters</p>
          </div>
        </div>

        {/* Quick Actions */}
        <div className={`grid gap-6 mb-8 ${isAdmin ? 'grid-cols-1 md:grid-cols-3' : 'grid-cols-1 md:grid-cols-2'}`}>
          <Link
            href="/dashboard/characters"
            className="metallic-card p-6 border-l-4 border-[var(--color-mystical-blue)] hover:border-[var(--color-glowing-cyan)] transition-all group"
          >
            <div className="flex items-center justify-between">
              <div>
                <h3 className="text-lg font-semibold text-[var(--color-mystical-blue)] mb-1 group-hover:text-[var(--color-glowing-cyan)] transition-colors">View Characters</h3>
                <p className="text-slate-400 text-sm">Manage your character details and clan</p>
              </div>
              <span className="text-3xl group-hover:scale-110 transition-transform">📋</span>
            </div>
          </Link>

          <Link
            href="/dashboard/topup"
            className="metallic-card p-6 border-l-4 border-[var(--color-royal-gold)] hover:border-[var(--color-glowing-cyan)] transition-all group"
          >
            <div className="flex items-center justify-between">
              <div>
                <h3 className="text-lg font-semibold text-[var(--color-royal-gold)] mb-1 group-hover:text-[var(--color-glowing-cyan)] transition-colors">Top-Up Credits</h3>
                <p className="text-slate-400 text-sm">Purchase credits via GCash</p>
              </div>
              <span className="text-3xl group-hover:scale-110 transition-transform">💳</span>
            </div>
          </Link>

          {isAdmin && (
            <Link
              href="/admin"
              className="metallic-card p-6 border-l-4 border-[var(--color-deep-crimson)] hover:border-[var(--color-crimson-glow)] transition-all group"
            >
              <div className="flex items-center justify-between">
                <div>
                  <h3 className="text-lg font-semibold text-[var(--color-deep-crimson)] mb-1 group-hover:text-[var(--color-crimson-glow)] transition-colors">Admin Panel</h3>
                  <p className="text-slate-400 text-sm">GameMaster Control Center</p>
                </div>
                <span className="text-3xl group-hover:scale-110 transition-transform">⚖️</span>
              </div>
            </Link>
          )}
        </div>

        {/* Voting Section */}
        <div className="metallic-card p-6 sm:p-8 mb-8 border-2 border-[var(--color-dark-steel)]">
          <div className="flex items-center justify-between mb-6">
            <div>
              <h2 className="text-2xl sm:text-3xl font-bold text-[var(--color-royal-gold)] mb-2">Vote for Rewards ðŸ—³ï¸</h2>
              <p className="text-slate-400 text-sm sm:text-base">Vote for our server and earn 5 Coins every 12 hours!</p>
            </div>
          </div>
          <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <a
              href="https://www.xtremetop100.com/in.php?site=1132376972"
              target="_blank"
              rel="noopener noreferrer"
              className="glow-button text-center"
            >
              Vote on XtremeTop100
            </a>
            <button
              onClick={handleClaimReward}
              disabled={claimingReward}
              className="crimson-button disabled:opacity-50"
            >
              {claimingReward ? 'Claiming...' : 'Claim Reward'}
            </button>
          </div>
        </div>

        {/* Voting History */}
        <div className="metallic-card p-6 sm:p-8 mb-8">
          <h2 className="text-2xl sm:text-3xl font-bold text-[var(--color-royal-gold)] mb-6">Voting History ðŸ“œ</h2>
          {votingLogs.length > 0 ? (
            <div className="space-y-3">
              {votingLogs.slice(0, 5).map((log) => (
                <div key={log.LogID} className="bg-[var(--color-charcoal)] border border-[var(--color-dark-steel)] rounded-lg p-4 flex items-center justify-between">
                  <div>
                    <p className="text-slate-200 font-medium text-sm sm:text-base">
                      {new Date(log.VoteTime).toLocaleDateString()}
                    </p>
                    <p className="text-slate-500 text-xs sm:text-sm">
                      {new Date(log.VoteTime).toLocaleTimeString()}
                    </p>
                  </div>
                  <span className="text-slate-500 text-xs sm:text-sm font-mono">{log.IP}</span>
                </div>
              ))}
            </div>
          ) : (
            <p className="text-slate-500 text-center py-8">No voting activity recorded yet</p>
          )}
        </div>

        {/* Account Settings */}
        <div className="metallic-card p-6 sm:p-8">
          <h2 className="text-2xl sm:text-3xl font-bold text-[var(--color-royal-gold)] mb-6">Account Settings âš™ï¸</h2>
          <Link
            href="/dashboard/change-password"
            className="glow-button inline-block"
          >
            Change Password
          </Link>
        </div>
      </div>
    </GlobalTheme>
  );
}


